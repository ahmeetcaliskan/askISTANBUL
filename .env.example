# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real secrets.

# ---------------------------------------------------------------------------
# Scraper — identifies the bot to the MediaWiki API.
# Wikivoyage asks scrapers to provide a contact address.
# ---------------------------------------------------------------------------
ASKISTANBUL_CONTACT=you@example.com

# ---------------------------------------------------------------------------
# Override the data directory if you don't want the default <repo>/data.
# ---------------------------------------------------------------------------
# ASKISTANBUL_DATA_DIR=/absolute/path/to/data

# ---------------------------------------------------------------------------
# API server (askistanbul-serve) — warm up models at startup vs. lazily on the
# first request. true = no first-query stall (default); false = faster boot.
# Override per-launch with `askistanbul-serve --warm` / `--no-warm`.
# ---------------------------------------------------------------------------
ASKISTANBUL_WARM=true

# ---------------------------------------------------------------------------
# Cross-encoder reranker — opt-in via --rerank or :rerank on.
# Default is fast and English-only; switch to bge-reranker-v2-m3 for stronger
# multilingual quality (Turkish place names, etc.) at ~6x latency.
# ---------------------------------------------------------------------------
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_FETCH_K=5
EMBEDDING_MODEL=intfloat/multilingual-e5-base
BIENCODER_FETCH_K=20

# ---------------------------------------------------------------------------
# Generator backend that answers queries — passed to LLMClientFactory.
# One of: ollama (local, default) | openrouter (hosted API).
# The server falls back to the other backend if the chosen one is unreachable.
# ---------------------------------------------------------------------------
GENERATOR_TYPE=ollama

# ---------------------------------------------------------------------------
# Local LLM generator (Ollama) — primary, per the project proposal.
# Run `ollama pull qwen2.5:7b` (or your chosen model) before first use.
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ---------------------------------------------------------------------------
# Hosted API fallbacks — set only if you plan to use them.
# Proposal targets: GPT-4o-mini and Claude Haiku.
# ---------------------------------------------------------------------------

JUDGE_TYPE=openrouter

OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_LLM_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_TITLE=askISTANBUL
# OPENROUTER_REFERER=http://localhost:5173
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
